{
  "version": 2,
  "name": "explorer",
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/node"
    },
    {
      "src": "dist/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/(.*)$",
      "dest": "/dist/$1"
    },
    {
      "src": "/.*",
      "dest": "/dist/index.html"
    }
  ]
}
